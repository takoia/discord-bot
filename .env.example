# --- Discord ---
# Bot token (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=
# Application (client) ID — Developer Portal > General Information
DISCORD_CLIENT_ID=
# Test guild ID — slash commands register instantly when scoped to a guild (ideal for demo).
# Leave empty to register globally (can take up to 1h to propagate).
GUILD_ID=

# --- core-backend ---
# Base URL of core-backend REST API, e.g. http://localhost:8080
BACKEND_URL=http://localhost:8080
# Shared secret. Sent by the bot as Bearer on outgoing calls, and required on
# incoming backend->bot events (Authorization: Bearer <SHARED_SECRET>).
SHARED_SECRET=change-me

# --- Bot HTTP server (backend -> bot events) ---
PORT=3000
